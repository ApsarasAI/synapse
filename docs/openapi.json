              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/openapi.json": {
      "get": {
        "tags": [],
        "operationId": "openapi_spec",
        "responses": {
          "200": {
            "description": "OpenAPI v3 JSON document"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdminAlert": {
        "type": "object",
        "required": [
          "severity",
          "code",
          "message",
          "count"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          }
        }
      },
      "AdminCapacityLimits": {
        "type": "object",
        "required": [
          "max_concurrency",
          "max_queue_depth",
          "max_queue_timeout_ms",
          "max_concurrent_executions_per_tenant"
        ],
        "properties": {
          "max_concurrency": {
            "type": "integer",
            "minimum": 0
          },
          "max_concurrent_executions_per_tenant": {
            "type": "integer",
            "minimum": 0
          },
          "max_queue_depth": {
            "type": "integer",
            "minimum": 0
          },
          "max_queue_timeout_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "AdminCapacityResponse": {
        "type": "object",
        "required": [
          "scheduler",
          "limits"
        ],
        "properties": {
          "limits": {
            "$ref": "#/components/schemas/AdminCapacityLimits"
          },
          "scheduler": {
            "$ref": "#/components/schemas/AdminSchedulerSnapshot"
          }
        }
      },
      "AdminErrorCount": {
        "type": "object",
        "required": [
          "code",
          "count"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "AdminMetricsSnapshot": {
        "type": "object",
        "required": [
          "success_total",
          "error_total",
          "queued_total",
          "capacity_rejected_total",
          "queue_timeout_total",
          "runtime_unavailable_total",
          "wall_timeout_total",
          "cpu_time_limit_exceeded_total",
          "memory_limit_exceeded_total",
          "sandbox_policy_blocked_total",
          "rate_limited_total",
          "quota_exceeded_total",
          "stdout_truncated_total",
          "stderr_truncated_total"
        ],
        "properties": {
          "capacity_rejected_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "cpu_time_limit_exceeded_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "error_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "memory_limit_exceeded_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "queue_timeout_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "queued_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "quota_exceeded_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "rate_limited_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "runtime_unavailable_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "sandbox_policy_blocked_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "stderr_truncated_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "stdout_truncated_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "success_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "wall_timeout_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "AdminOverviewResponse": {
        "type": "object",
        "required": [
          "service",
          "metrics",
          "alerts",
          "top_error_codes",
          "recent_failures"
        ],
        "properties": {
          "alerts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminAlert"
            }
          },
          "metrics": {
            "$ref": "#/components/schemas/AdminMetricsSnapshot"
          },
          "recent_failures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RequestSummary"
            }
          },
          "service": {
            "$ref": "#/components/schemas/AdminServiceStatus"
          },
          "top_error_codes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminErrorCount"
            }
          }
        }
      },
      "AdminRequestAuditResponse": {
        "type": "object",
        "required": [
          "request_id",
          "events"
        ],
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuditEvent"
            }
          },
          "request_id": {
            "type": "string"
          }
        }
      },
      "AdminRequestsResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RequestSummary"
            }
          }
        }
      },
      "AdminRuntimeEntry": {
        "type": "object",
        "required": [
          "language",
          "version",
          "command",
          "install_source",
          "active",
          "status"
        ],
        "properties": {
          "active": {
            "type": "boolean"
          },
          "command": {
            "type": "string"
          },
          "install_source": {
            "$ref": "#/components/schemas/RuntimeInstallSource"
          },
          "language": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "AdminRuntimeResponse": {
        "type": "object",
        "required": [
          "active",
          "installed"
        ],
        "properties": {
          "active": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminRuntimeEntry"
            }
          },
          "installed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminRuntimeEntry"
            }
          }
        }
      },
      "AdminSchedulerSnapshot": {
        "type": "object",
        "required": [
          "active_total",
          "queued_total",
          "admitted_total",
          "rejected_total",
          "queue_timeout_total",
          "queue_wait_time_ms_total"
        ],
        "properties": {
          "active_total": {
            "type": "integer",
            "minimum": 0
          },
          "admitted_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "queue_timeout_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "queue_wait_time_ms_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "queued_total": {
            "type": "integer",
            "minimum": 0
          },
          "rejected_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "AdminServiceStatus": {
        "type": "object",
        "required": [
          "status",
          "version",
