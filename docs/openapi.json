            "description": "Installed and active runtimes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminRuntimeResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/audits/{request_id}": {
      "get": {
        "tags": [],
        "operationId": "get_audit_log",
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "description": "Execution request id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-synapse-tenant-id",
            "in": "header",
            "description": "Optional tenant selector used for access control",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Persisted audit trail",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AuditEvent"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "403": {
            "description": "Tenant access forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "404": {
            "description": "Audit record not found or not visible to current tenant"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/execute": {
      "post": {
        "tags": [],
        "operationId": "execute_request",
        "parameters": [
          {
            "name": "x-synapse-request-id",
            "in": "header",
            "description": "Optional request correlation id. Body request_id wins when both are present.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-synapse-tenant-id",
            "in": "header",
            "description": "Optional tenant selector. Body tenant_id wins when both are present.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Sandbox execution request",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Execution completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input, invalid JSON, unsupported language, or invalid headers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "403": {
            "description": "Tenant access forbidden or sandbox policy blocked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "408": {
            "description": "Queue timeout, wall timeout, or CPU time limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "413": {
            "description": "Memory limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "424": {
            "description": "Requested runtime unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "429": {
            "description": "Tenant quota exceeded or rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "500": {
            "description": "Execution, audit, or IO failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "503": {
            "description": "Execution capacity rejected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
