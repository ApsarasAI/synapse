    "/admin/requests/{request_id}": {
      "get": {
        "tags": [],
        "operationId": "admin_get_request",
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "description": "Execution request id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Single request summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestSummary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "404": {
            "description": "Summary not found or not visible to current tenant"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/admin/requests/{request_id}/audit": {
      "get": {
        "tags": [],
        "operationId": "admin_get_request_audit",
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "description": "Execution request id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Single request summary plus audit trail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminRequestAuditResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecuteResponse"
                }
              }
            }
          },
          "404": {
            "description": "Summary or audit record not found, or record hidden from current tenant"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/admin/runtime": {
      "get": {
        "tags": [],
